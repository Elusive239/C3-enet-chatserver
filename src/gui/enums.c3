{
	MOUSEBUTTON_NONE,
	MOUSEBUTTON_PRESSED,
	MOUSEBUTTON_HELD,
	MOUSEBUTTON_RELEASED
}

constdef UIResizeDirection : inline int
{
	RESIZE_NONE,
	RESIZE_LEFT,
	RESIZE_TOP,
	RESIZE_RIGHT,
	RESIZE_BOTTOM,

	RESIZE_LEFT_TOP,
	RESIZE_RIGHT_TOP,
	RESIZE_LEFT_BOTTOM,
	RESIZE_RIGHT_BOTTOM
}

constdef UIButtonState : inline int
{
	BUTTON_STATE_NORMAL,
	BUTTON_STATE_HOVER,
	BUTTON_STATE_CLICK
}